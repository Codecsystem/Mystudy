```cpp
    auto add=[&](int cnt,int siz,int val)->void{
        for(int i=cnt;i>=1;i--){
            for(int j=siz;j>=val;j--){
                dp[i][j]+=dp[i-1][j-val];
            }
        }
    };
    auto del=[&](int cnt,int siz,int val)->void{
        for(int i=1;i<=cnt;i++){
            for(int j=val;j<=siz;j++){
                dp[i][j]-=dp[i-1][j-val];
            }
        }
    };
```

